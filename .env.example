# PagedataLooM Portal — environment variables
# Copy to .env.local and populate before running Portal-B

# Microsoft Entra ID (PagedataLooM app registration — separate from zOz)
VITE_MSAL_CLIENT_ID=
VITE_MSAL_TENANT_ID=
VITE_MSAL_REDIRECT_URI=http://localhost:5173

# PageLooM backend
VITE_API_BASE_URL=https://func-pageloom-dev-weu.azurewebsites.net

# Azure Static Web Apps (populated at deploy time)
VITE_APP_ENV=development
